# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.

# ---------- Required ----------

PLM_PASSWORD=change-me
PLM_SESSION_SECRET=use-a-long-random-string-here

# Generate a good secret:
#   python3 -c "import secrets; print(secrets.token_hex(32))"

# ---------- Optional ----------

# Port the app listens on (default: 2026)
# PLM_PORT=2026

# URL prefix when Caddy reverse-proxies at a subpath (e.g. /plm)
# PLM_ROOT_PATH=/plm

# ---------- Remote MCP server (optional — only needed with --profile mcp) ----------

# Port the MCP HTTP server listens on (default: 2027)
# PLM_MCP_PORT=2027

# WorkOS AuthKit domain — found in the WorkOS dashboard under "AuthKit domain"
# WORKOS_AUTHKIT_DOMAIN=your-slug.authkit.app

# Public base URL of the MCP server (must match the Caddy proxy path)
# PLM_MCP_BASE_URL=https://yourdomain/plm-mcp
